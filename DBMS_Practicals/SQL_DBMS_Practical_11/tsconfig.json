{
  "compilerOptions": {
    /* File Layout */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Environment Settings */
    "module": "Node16",           // This will output CommonJS if "type" isn't "module" in package.json
    "moduleResolution": "Node16", 
    "target": "ES2022", 
    "lib": ["ES2022"],
    "types": ["node"],
    "esModuleInterop": true, 
    "forceConsistentCasingInFileNames": true,

    /* Other Outputs */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    /* Stricter Typechecking Options */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* Style Options */
    "verbatimModuleSyntax": false, 
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
